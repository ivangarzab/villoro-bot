# Environment: set to "dev" for local development, leave unset for production
ENV=dev

# Discord bot tokens
DEV_TOKEN=your_dev_discord_token_here
TOKEN=your_prod_discord_token_here

# kluvs-brain Supabase credentials (RAG backend)
BRAINS_SUPABASE_URL=https://your-project.supabase.co
BRAINS_SUPABASE_KEY=your_supabase_service_role_key_here

# OpenAI API key (used by kluvs-brain for embeddings + GPT-4o)
KEY_OPEN_AI=sk-your_openai_key_here
